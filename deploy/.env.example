# ================= 科研数据共享平台 · 环境配置 =================
# 复制为项目根目录 .env 后填写。带 ★ 的是腾讯云部署必须由你提供的。

# ---- 数据库（腾讯云 TencentDB for PostgreSQL）★ ----
# 格式: postgresql+psycopg2://用户名:密码@内网地址:5432/库名
# 在腾讯云控制台创建 TencentDB PG 实例后，用其“内网地址”（与 CVM 同 VPC）。
DATABASE_URL=postgresql+psycopg2://rhub:CHANGE_ME@10.0.0.2:5432/research_hub
# 若想同机自装 PostgreSQL（省钱，非托管），设为 true 并把上面地址改为 db:5432
LOCAL_DB=false
POSTGRES_USER=rhub
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=research_hub

# ---- 鉴权 ★ ----
# 用 `openssl rand -hex 32` 生成一串随机值填入
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=1209600

# ---- 文件存储（腾讯云 COS）★ ----
# STORAGE_BACKEND=cos 用对象存储；=local 用容器内目录（仅测试）
STORAGE_BACKEND=cos
COS_BUCKET=research-hub-1300000000        # ★ 你的存储桶名（含 APPID 后缀）
COS_REGION=ap-beijing                      # ★ 存储桶地域
COS_SECRET_ID=CHANGE_ME                    # ★ 腾讯云 API 密钥 SecretId
COS_SECRET_KEY=CHANGE_ME                   # ★ 腾讯云 API 密钥 SecretKey
COS_SIGNED_URL_TTL=600

# ---- AI 网关（可选，二期启用；一期可留 none）----
AI_PROVIDER=none                           # none | claude | openai | local
AI_GATEWAY_URL=
AI_API_KEY=

# ---- 其它 ----
# 你的域名/公网访问来源，逗号分隔；* 表示不限（内测可用，生产建议收紧）
ALLOWED_ORIGINS=*
MAX_UPLOAD_MB=50
WEB_CONCURRENCY=3
SEED_ON_START=true                         # 首次拉起自动灌入 seed 假数据；上线后可设 false

# ---- 平台品牌（8.4，占位可改）----
PLATFORM_NAME_ZH=科研数据共享平台
PLATFORM_NAME_EN=Research Hub
PLATFORM_SLOGAN_ZH=让每一份自建数据都可信、可复用、可归属
PLATFORM_SLOGAN_EN=Make every self-built dataset trustworthy, reusable and attributable
